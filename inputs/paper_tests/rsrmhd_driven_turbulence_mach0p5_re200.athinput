# Production test: 128^2 mechanically driven visco-resistive SRMHD turbulence.
#
# Mach convention: M_turb = v_rms/c_s with the initial relativistic sound speed
# c_s^2 = gamma*p/(rho + gamma*p/(gamma-1)).  For rho=p=1 and gamma=5/3,
# c_s=0.6900655593423543 and the M_turb=0.5 target is v_rms=0.3450327796711771.
# The injection length is L_drive=L/k_peak=1/2, so t_eddy=L_drive/v_rms=
# 1.449137674618944.  The run spans ten target turnover times.  Uniform
# eta=nu_sh=v_rms*L_drive/200 gives nominal Re=Rm=200 and Pm=1.

<comment>
problem = 128^2 M_turb=0.5 driven visco-resistive SRMHD, Re=Rm=200

<job>
basename = driven_mach0p5_re200

<mesh>
nghost = 4
nx1 = 128
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic

nx2 = 128
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic

nx3 = 1
x3min = -0.5
x3max = 0.5
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 32
nx2 = 32
nx3 = 1

<coord>
special_rel = true

<time>
evolution = dynamic
integrator = imex2
cfl_number = 0.4
tlim = 14.49137674618944
nlim = -1
ndiag = 100

<mhd>
eos = ideal
gamma = 1.6666666666666667
resistive_rel = true
resistivity_model = uniform
resistivity = 0.0008625819491779428
relativistic_viscosity = true
linearized_shear_target_1d = false
shear_viscosity = 0.0008625819491779428
shear_relaxation_time = 0.02
shear_chi_max = 2.0
rsolver = llf
reconstruct = wenoz
fofc = true
fofc_force = false

<problem>
pgen_name = rsrmhd_decaying_turbulence
user_hist = true
density = 1.0
pressure = 1.0
velocity_rms = 0.3450327796711771
magnetic_rms = 0.05
profile_name = driven_mach0p5_re200

<velocity_spectral_ic>
nlow = 1
nhigh = 3
spectrum = parabolic
iseed = 1837

<magnetic_spectral_ic>
nlow = 1
nhigh = 3
spectrum = parabolic
iseed = 918273

<turb_driving>
relativistic_forcing = mechanical
tcorr = 1.449137674618944
accel_rms = 0.30
nlow = 1
nhigh = 3
driving_geometry = isotropic
driving_profile = parabola
sol_weight = 1.0
parabola_peak = 2.0
parabola_width = 0.5

# Fifty history samples and twenty full-resolution movie frames per turnover time.
<output1>
file_type = hst
dt = 0.02898275349237887
user_hist_only = true
data_format = %20.12e

<output2>
file_type = bin
variable = mhd_w_bcc
id = prim
dt = 0.07245688373094719

<output3>
file_type = bin
variable = turb_force
id = force
dt = 0.07245688373094719
