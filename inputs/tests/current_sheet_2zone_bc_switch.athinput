# AthenaXXX regression input for current_sheet_2zone BC switching

<comment>
problem   = current_sheet_2zone ghost-zone BC switch regression

<job>
basename  = cs2_bc_switch

<mesh>
nghost    = 3
nx1       = 32
x1min     = -1.0
x1max     = 1.0
ix1_bc    = diode
ox1_bc    = diode

nx2       = 24
x2min     = -1.0
x2max     = 1.0
ix2_bc    = periodic
ox2_bc    = periodic

nx3       = 1
x3min     = -0.5
x3max     = 0.5
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 32
nx2       = 24
nx3       = 1

<time>
evolution  = dynamic
integrator = rk3
cfl_number = 0.4
nlim       = -1
tlim       = 0.06
ndiag      = 1

<mhd>
eos               = ideal
resistivity       = ohmic
ohmic_resistivity = 0.0035
reconstruct       = plm
rsolver           = hlld
gamma             = 1.6666666666666667

<problem>
iprob    = 3
d0       = 1.0
ng       = 1.0
b0       = 1.0
a0       = 0.5
bg       = 0.0
kval     = 1.0
p0       = 0.6
epsp     = 0.2
t_switch = 0.03

<output1>
file_type   = tab
variable    = mhd_u
id          = x1u
data_format = %24.16e
dt          = 0.012
slice_x2    = 0.0
slice_x3    = 0.0
ghost_zones = true

<output2>
file_type   = tab
variable    = mhd_u
id          = x2u
data_format = %24.16e
dt          = 0.012
slice_x1    = 0.03125
slice_x3    = 0.0
ghost_zones = true

<output3>
file_type   = tab
variable    = mhd_bcc
id          = x1b
data_format = %24.16e
dt          = 0.012
slice_x2    = 0.0
slice_x3    = 0.0
ghost_zones = true

<output4>
file_type   = tab
variable    = mhd_bcc
id          = x2b
data_format = %24.16e
dt          = 0.012
slice_x1    = 0.03125
slice_x3    = 0.0
ghost_zones = true
