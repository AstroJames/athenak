# AthenaK input for one-dimensional conservative relativistic-shear transport

<job>
basename  = rsrmhd_viscous_transport

<mesh>
nghost    = 2
nx1       = 128
x1min     = 0.0
x1max     = 1.0
ix1_bc    = periodic
ox1_bc    = periodic
nx2       = 1
x2min     = -0.5
x2max     = 0.5
ix2_bc    = periodic
ox2_bc    = periodic
nx3       = 1
x3min     = -0.5
x3max     = 0.5
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 64
nx2       = 1
nx3       = 1

<coord>
special_rel = true

<time>
evolution  = dynamic
integrator = imex2
cfl_number = 0.4
tlim       = 0.25

<mhd>
eos                       = ideal
gamma                     = 1.6666666666666667
resistive_rel             = true
resistivity               = 1.0
relativistic_viscosity    = true
shear_viscosity           = 0.0
shear_relaxation_time     = 1.0e20
shear_chi_max             = 2.0
rsolver                   = llf
reconstruct               = plm

<problem>
pgen_name        = rsrmhd_roundtrip
viscous_transport = true
