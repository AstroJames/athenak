# Two-dimensional mechanically driven, resistive-viscous SRMHD turbulence.

<comment>
problem = 2D coupled SRMHD turbulence driven by enthalpy-weighted proper acceleration

<job>
basename = rsrmhd_driven_turbulence

<mesh>
nghost = 2
nx1 = 64
x1min = 0.0
x1max = 1.0
ix1_bc = periodic
ox1_bc = periodic

nx2 = 64
x2min = 0.0
x2max = 1.0
ix2_bc = periodic
ox2_bc = periodic

nx3 = 1
x3min = -0.5
x3max = 0.5
ix3_bc = periodic
ox3_bc = periodic

<meshblock>
nx1 = 32
nx2 = 32
nx3 = 1

<coord>
special_rel = true

<time>
evolution = dynamic
integrator = imex2
cfl_number = 0.4
tlim = 0.5
nlim = -1
ndiag = 20

<mhd>
eos = ideal
gamma = 1.6666666666666667
resistive_rel = true
resistivity_model = uniform
resistivity = 0.002
relativistic_viscosity = true
linearized_shear_target_1d = false
shear_viscosity = 0.002
shear_relaxation_time = 0.02
shear_chi_max = 2.0
rsolver = llf
reconstruct = plm
fofc = false
fofc_force = false

<problem>
pgen_name = rsrmhd_decaying_turbulence
user_hist = true
density = 1.0
pressure = 1.0
velocity_rms = 0.02
magnetic_configuration = random
magnetic_rms = 0.05
plasma_beta = 1.0
profile_name = rsrmhd_driven_turbulence

<velocity_spectral_ic>
nlow = 1
nhigh = 2
spectrum = parabolic
iseed = 1837

<magnetic_spectral_ic>
nlow = 1
nhigh = 2
spectrum = parabolic
iseed = 918273

<turb_driving>
relativistic_forcing = mechanical
tcorr = 0.2
accel_rms = 0.25
nlow = 1
nhigh = 2
driving_geometry = isotropic
driving_profile = band
sol_weight = 1.0

<output1>
file_type = hst
dt = 0.05
user_hist_only = true
data_format = %20.12e

<output2>
file_type = bin
variable = mhd_w_bcc
id = prim
dt = 0.25

<output3>
file_type = bin
variable = turb_force
id = force
dt = 0.25
