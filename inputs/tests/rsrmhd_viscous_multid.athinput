# AthenaK input for a transverse Israel--Stewart wave propagating along x2

<job>
basename  = rsrmhd_viscous_multid

<mesh>
nghost    = 2
nx1       = 8
x1min     = -0.5
x1max     = 0.5
ix1_bc    = periodic
ox1_bc    = periodic
nx2       = 256
x2min     = 0.0
x2max     = 1.0
ix2_bc    = periodic
ox2_bc    = periodic
nx3       = 1
x3min     = -0.5
x3max     = 0.5
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 8
nx2       = 128
nx3       = 1

<coord>
special_rel = true

<time>
evolution  = dynamic
integrator = imex2
cfl_number = 0.4
nlim       = -1
tlim       = 0.4

<mhd>
eos                        = ideal
gamma                      = 1.6666666666666667
resistive_rel              = true
resistivity                = 1.0
relativistic_viscosity     = true
linearized_shear_target_1d = false
shear_viscosity            = 0.05
shear_relaxation_time      = 0.2
shear_chi_max              = 2.0
rsolver                    = llf
reconstruct                = plm
fofc                       = false
fofc_force                 = false  # verification switch; leave false in simulations

<problem>
pgen_name         = rsrmhd_roundtrip
viscous_telegraph = true
wave_direction    = 2
amplitude         = 1.0e-4
viscous_diagnostic_name = none
background_b1       = 0.0
background_b2       = 0.0
background_b3       = 0.0
background_e1       = 0.0
background_e2       = 0.0
background_e3       = 0.0

<output1>
file_type = rst
dcycle    = 0
