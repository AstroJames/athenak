# AthenaXXX regression input for Biermann battery gradient test

<comment>
problem   = Biermann battery with misaligned linear gradients

<job>
basename  = biermann_grad

<mesh>
nghost    = 2
nx1       = 64
x1min     = -0.5
x1max     = 0.5
ix1_bc    = outflow
ox1_bc    = outflow

nx2       = 32
x2min     = -0.5
x2max     = 0.5
ix2_bc    = outflow
ox2_bc    = outflow

nx3       = 1
x3min     = -0.5
x3max     = 0.5
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 64
nx2       = 32
nx3       = 1

<time>
evolution  = dynamic
integrator = rk1
cfl_number = 1.0e-4
nlim       = 1
tlim       = 1.0
ndiag      = 1

<mhd>
eos              = ideal
biermann_coeff   = 1.0e-3
reconstruct      = plm
rsolver          = hlld
gamma            = 1.4

<problem>
pgen_name = biermann_gradient
rho0      = 1.0
drho_dx1  = 0.5
p0        = 1.0
dp_dx1    = 0.0
dp_dx2    = 0.25
use_theta_mode = false
theta_deg      = 90.0
drho_mag       = 0.5
dp_mag         = 0.25
balance_pressure_force = false

<output1>
file_type   = tab
variable    = mhd_bcc
id          = bz
data_format = %24.16e
dt          = 1.0e-8
slice_x2    = 0.0
slice_x3    = 0.0
